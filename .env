# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgres://yula:yula@localhost:5432/yula
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Phone hashing - server-side pepper (combined with client SHA-256 for defense-in-depth)
PHONE_HASH_PEPPER=change-me-to-a-long-random-string

# SMS Provider (NetGSM for Turkey)
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=YULA

# Twilio (alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890

# S3 / R2
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=yula-uploads

# Firebase Cloud Messaging
FCM_SERVER_KEY=
